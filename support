                  <iconify-icon icon="${item.icon}" class="text-[#FEFD0C] text-2xl"></iconify-icon>
                </div>
                <div class="flex-1">
                  <div class="flex items-center mb-1">
                    <h3 class="text-lg font-bold text-black group-hover:text-[#FEFD0C] transition-colors duration-300 mr-2">${item.title}</h3>
                    <span class="text-xs bg-[#FEFD0C]/10 text-[#FEFD0C] px-2 py-1 rounded-full border border-[#FEFD0C]/20">${item.category}</span>
                  </div>
                  <p class="text-black-400 group-hover:text-black-300 transition-colors duration-300 text-sm mb-2">${item.description}</p>
                  <div class="text-[#FEFD0C] font-medium text-sm">${item.handle || item.email}</div>
                </div>
                <svg class="w-5 h-5 text-black-500 group-hover:text-[#FEFD0C] transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                </svg>
              </a>
            `).join("")}
          </div>
        </div>
      `;
    }

    function renderFaq(){
      const categories = ["All", ...Array.from(new Set(faqItems.map(i=>i.category)))];
      // filter
      const list = selectedCategory==="All" ? faqItems : faqItems.filter(i=>i.category===selectedCategory);

      contentEl.innerHTML = `
        <div class="max-w-4xl mx-auto">
          <div class="flex flex-wrap justify-center gap-2 mb-8">
            ${categories.map(cat=>`
              <button data-cat="${cat}" class="cat-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 ${selectedCategory===cat ? 'bg-[#FEFD0C] text-black shadow-lg' : 'bg-black/40 backdrop-blur-md border border-[#FEFD0C]/10 text-[#FEFD0C] hover:border-[#FEFD0C]/30'}">
                ${cat}
              </button>
            `).join("")}
          </div>
          <div class="space-y-4">
            ${list.map((faq,idx)=>`
              <div class="faq-item bg-black/40 backdrop-blur-xl border border-[#FEFD0C]/10 rounded-2xl shadow-2xl shadow-black/50 overflow-hidden hover:border-[#FEFD0C]/30 transition-all duration-500" data-index="${idx}">
                <button class="w-full px-6 py-5 text-left flex justify-between items-center focus:outline-none hover:bg-[#FEFD0C]/5 transition-colors duration-300">
                  <div class="flex items-center">
                    <span class="text-lg font-semibold text-black mr-3">${faq.question}</span>
                    <span class="text-xs bg-[#FEFD0C]/10 text-[#FEFD0C] px-2 py-1 rounded-full border border-[#FEFD0C]/20">${faq.category}</span>
                  </div>
                  <svg class="chev w-6 h-6 text-[#FEFD0C] transform transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <div class="answer px-6 transition-all duration-300 ease-in-out overflow-hidden max-h-0 opacity-0">
                  <div class="border-t border-[#FEFD0C]/10 pt-4 pb-6">
                    <p class="text-gray-300 leading-relaxed">${faq.answer}</p>
                  </div>
                </div>
              </div>
            `).join("")}
          </div>
        </div>
      `;

      // category buttons
      document.querySelectorAll(".cat-btn").forEach(btn=>{
        btn.addEventListener("click", ()=>{
          selectedCategory = btn.getAttribute("data-cat");
          renderFaq();
        });
      });
      // faq toggles
      document.querySelectorAll(".faq-item").forEach((wrap)=>{
        const btn = wrap.querySelector("button");
        const ans = wrap.querySelector(".answer");
        const chev = wrap.querySelector(".chev");
        btn.addEventListener("click", ()=>{
          const open = ans.style.maxHeight && ans.style.maxHeight !== "0px";
          document.querySelectorAll(".answer").forEach(a=>{ a.style.maxHeight="0px"; a.style.opacity="0"; });
          document.querySelectorAll(".chev").forEach(c=>c.classList.remove("rotate-180"));
          if (!open) {
            ans.style.maxHeight = ans.scrollHeight + "px";
            ans.style.opacity = "1";
            chev.classList.add("rotate-180");
          }
        });
      });
    }

    function renderActive(){
      tabsEl.querySelectorAll(".tab-btn").forEach(btn=>{
        const isActive = btn.getAttribute("data-tab")===activeTab;
        btn.classList.toggle("bg-[#FEFD0C]", isActive);
        btn.classList.toggle("text-black", isActive);
        btn.classList.toggle("shadow-lg", isActive);
        btn.classList.toggle("transform", isActive);
        btn.classList.toggle("scale-105", isActive);
        if (!isActive){
          btn.classList.add("text-Black");
          btn.classList.remove("text-black");
        }
      });
    }

    function render(){
      renderActive();
      if (activeTab==="channels") renderChannels();
      if (activeTab==="social") renderSocial();
      if (activeTab==="faq") renderFaq();
    }

    // Tab handlers
    tabsEl.querySelectorAll(".tab-btn").forEach(btn=>{
      btn.addEventListener("click", ()=>{
        activeTab = btn.getAttribute("data-tab");
        render();
      });
    });

    // Init
    render();
  </script>
  <script src="//code.jivosite.com/widget/PrCZ5RCx2Y" async=""></script>
